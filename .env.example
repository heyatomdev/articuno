# Environment
NODE_ENV=development

# Server
PORT=3000
# Comma-separated origins, ex: https://cms.example.com,https://admin.example.com
CORS_ORIGIN=
# Enable when running behind a reverse proxy/load balancer
TRUST_PROXY=false
# Public base URL used in logs and integrations
BASE_URL=

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/articuno"
