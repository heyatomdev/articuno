// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id              String  @id @default(uuid())
  slug            String  @unique
  name            String
  description     String?
  domain          String  @unique
  defaultLanguage String  @default("it")

  apiKey  String  @unique // Hash della chiave (tipo password)
  enabled Boolean @default(true)

  users               User[]
  categories          Category[]
  tags                Tag[]
  articles            Article[]
  articleTranslations ArticleTranslation[]
  comments            Comment[]
  dailyStats          DailyStats[]
  reports             Report[]
  bannedWords         BannedWord[]
  notifications       Notification[]
  webhookEvents       WebhookEvent[]

  // Configurazione Webhook per notifiche e moderazione
  webhookUrl    String?
  webhookSecret String?

  // Fileharbor storage configuration
  fileharborEndpoint String?
  fileharborApiKey   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenants")
}

model WebhookEvent {
  id      String @id @default(uuid())
  event   String
  payload Json

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sentAt      DateTime?
  attempts    Int       @default(0)
  lastError   String?
  nextRetryAt DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId, sentAt, nextRetryAt])
  @@map("webhook_events")
}

model User {
  id         String @id @default(uuid())
  externalId String
  tenantId   String
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  language  String  @default("it")
  username  String?
  avatarUrl String?

  status UserStatus @default(ACTIVE)
  role   UserRole   @default(MEMBER)

  articles      Article[]
  comments      Comment[]
  likes         Like[]
  bookmarks     Bookmark[]
  notifications Notification[]
  sessions      SessionStorage[]

  adminCredentials AdminCredentials?

  reportsFiled     Report[] @relation("ReporterReports")
  reportsModerated Report[] @relation("ModeratorReports")

  createdAt DateTime @default(now())

  @@unique([externalId, tenantId])
  @@map("users")
}

model AdminCredentials {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Email admin (potrebbe essere diversa dall'email dell'app)
  email String @unique

  // Password hash (bcrypt)
  password String

  // Autenticazione multi-factor (opzionale)
  totpSecret  String?
  totpEnabled Boolean @default(false)

  // Audit
  lastLoginAt          DateTime?
  lastPasswordChangeAt DateTime  @default(now())
  loginAttempts        Int       @default(0)
  isLockedOut          Boolean   @default(false)
  lockedUntil          DateTime?

  // Soft delete per disattivare senza cancellare
  disabledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("admin_credentials")
}

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  color       String?
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  articles Article[] @relation("ArticleCategories")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Tag {
  id       String @id @default(uuid())
  name     String
  slug     String @unique
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  articles Article[] @relation("ArticleTags")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tags")
}

model Article {
  id            String  @id @default(uuid())
  coverImage    String?
  featured      Boolean @default(false)
  views         Int     @default(0)
  likesCount    Int     @default(0)
  commentsCount Int     @default(0)

  status ContentStatus @default(DRAFT)

  // Relazioni strutturali
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  categoryId String
  category   Category @relation("ArticleCategories", fields: [categoryId], references: [id])
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  translations ArticleTranslation[]
  commentsList Comment[]
  likes        Like[]
  bookmarks    Bookmark[]

  // Many-to-many relation with tags
  tags Tag[] @relation("ArticleTags")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("articles")
}

model ArticleTranslation {
  id              String  @id @default(uuid())
  languageCode    String // "it", "en", etc.
  title           String
  content         String  @db.Text
  excerpt         String  @db.Text
  slug            String
  metaTitle       String?
  metaDescription String?

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([articleId, languageCode])
  @@unique([tenantId, slug])
  @@map("article_translations")
}

model Comment {
  id        String  @id @default(uuid())
  content   String
  authorId  String
  author    User    @relation(fields: [authorId], references: [id])
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  status      ContentStatus @default(VISIBLE)
  reportCount Int           @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model Like {
  id        String  @id @default(uuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String // Denormalizziamo il tenantId per query di analytics veloci

  createdAt DateTime @default(now())

  @@unique([articleId, userId]) // Impedisce duplicati
  @@index([tenantId])
  @@map("likes")
}

model Bookmark {
  id        String  @id @default(uuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String

  createdAt DateTime @default(now())

  @@unique([articleId, userId])
  @@index([userId, tenantId]) // Ottimizza la query "i miei preferiti"
  @@map("bookmarks")
}

model Notification {
  id      String @id @default(uuid())
  type    String
  title   String
  message String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Logica Outbox per Webhook
  sentToClient Boolean   @default(false)
  readAt       DateTime?

  createdAt DateTime @default(now())

  @@map("notifications")
}

model DailyStats {
  id                String   @id @default(uuid())
  date              DateTime
  articlesPublished Int      @default(0)
  totalViews        Int      @default(0)
  totalLikes        Int      @default(0)
  totalComments     Int      @default(0)
  totalBookmarks    Int      @default(0)
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, tenantId])
  @@map("daily_stats")
}

model Report {
  id          String       @id @default(uuid())
  reason      String // Es: "SPAM", "OFFENSIVE", "INACCURATE"
  description String?      @db.Text
  status      ReportStatus @default(PENDING)

  // Polimorfismo semplificato: cosa stiamo segnalando?
  targetType TargetType // ENUM: ARTICLE, COMMENT, USER
  targetId   String // L'ID dell'entità segnalata

  reporterId    String
  reporter      User     @relation("ReporterReports", fields: [reporterId, tenantId], references: [externalId, tenantId], onDelete: Cascade)
  moderatorId   String?
  moderator     User?    @relation("ModeratorReports", fields: [moderatorId, tenantId], references: [externalId, tenantId], onDelete: SetNull)
  moderatorNote String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId, status])
  @@map("reports")
}

model BannedWord {
  id       String @id @default(uuid())
  word     String
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([word, tenantId])
  @@map("banned_words")
}

model SessionStorage {
  id String @id @default(cuid())

  // Chi ha effettuato il login
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId String

  // User snapshot (per performance, non per autorizzazione)
  userRole   UserRole
  externalId String

  // Timing
  createdAt      DateTime @default(now())
  expiresAt      DateTime
  lastAccessedAt DateTime @default(now())

  // Sicurezza
  ipAddress String?
  userAgent String?

  @@index([id])
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model ApiKey {
  id String @id @default(uuid())

  // Public identifier
  keyId  String @unique
  secret String

  // Metadati
  name     String // "CI/CD deploy", "External bot"
  tenantId String
  userId   String

  // Autorizzazioni
  scopes String[] // ["articles:write", "reports:read"]

  // Audit
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  lastUsedAt DateTime?

  // Soft delete
  revokedAt DateTime?

  @@index([tenantId])
  @@index([keyId])
  @@unique([tenantId, keyId])
  @@map("api_keys")
}

model AuditLog {
  // Primary key
  id String @id @default(uuid())

  // Timing (UTC)
  timestamp DateTime @default(now())

  // Tenant context (MANDATORY)
  tenantId String

  // Actor (who did it)
  actorUserId String // externalId of user who performed action
  actorRole   UserRole // cached role at time of action (for audit trail)

  // Action details
  action       AuditAction
  resourceType AuditResourceType
  resourceId   String // ID of what was changed (article, user, comment, etc)
  resourceName String? // optional: name/slug for easier reading (e.g. article title)

  // What changed
  changesBefore Json? // previous state (optional, depends on action)
  changesAfter  Json? // new state (optional, depends on action)
  changeSummary String? // human-readable summary (e.g. "Status: draft → published")

  // Indexes for query performance
  @@index([tenantId])
  @@index([tenantId, timestamp])
  @@index([tenantId, action])
  @@index([tenantId, actorUserId])
  @@index([tenantId, resourceId])
  @@index([timestamp]) // For retention cleanup queries
  @@map("audit_logs")
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum TargetType {
  ARTICLE
  COMMENT
  USER
}

enum ContentStatus {
  PUBLISHED
  DRAFT
  UNDER_REVIEW
  HIDDEN
  BANNED
  VISIBLE // Per i commenti
}

enum UserStatus {
  ACTIVE
  BANNED // L'utente non può più interagire
  SHADOW_BANNED // L'utente interagisce ma nessuno vede i suoi contenuti
}

enum UserRole {
  TENANT_ADMIN // Può gestire tutto all'interno del tenant, inclusi utenti e configurazioni
  SUPER_MODERATOR // Può gestire contenuti e moderazione, ma non utenti o configurazioni
  EDITOR // Può creare e gestire articoli, ma non utenti o configurazioni
  MODERATOR // Può gestire commenti e segnalazioni, ma non articoli o utenti
  MEMBER // Utente normale, può leggere e interagire con i contenuti
}

enum AuditAction {
  // User management
  USER_CREATED
  USER_UPDATED_ROLE
  USER_STATUS_CHANGED
  USER_DELETED

  // Article operations
  ARTICLE_CREATED
  ARTICLE_UPDATED
  ARTICLE_DELETED
  ARTICLE_STATUS_CHANGED // published, draft, archived

  // Comment operations
  COMMENT_CREATED
  COMMENT_UPDATED
  COMMENT_DELETED
  COMMENT_STATUS_CHANGED // approved, rejected, hidden

  // Category management
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED

  // Tag management
  TAG_CREATED
  TAG_UPDATED
  TAG_DELETED

  // Reports / Moderation
  REPORT_CREATED
  REPORT_STATUS_CHANGED // resolved, dismissed, pending

  // Banned words
  BANNED_WORD_CREATED
  BANNED_WORD_DELETED

  // Permission/Role changes (critical)
  ROLE_ASSIGNMENT_CHANGED
}

enum AuditResourceType {
  USER
  ARTICLE
  COMMENT
  REPORT
  BANNED_WORD
  TAG
  CATEGORY
}
